FROM composer:2.7 AS vendor
WORKDIR /app
COPY composer.json composer.lock ./
COPY Modules/Wacore/composer.json Modules/Wacore/composer.json
RUN --mount=type=cache,target=/tmp/cache composer install \
    --no-dev \
    --no-interaction \
    --no-progress \
    --optimize-autoloader \
    --ignore-platform-reqs \
    --prefer-dist

FROM node:22-alpine AS build
WORKDIR /app
COPY package.json package-lock.json ./
COPY Modules/Wacore/package.json Modules/Wacore/package.json
RUN npm ci
COPY . .
RUN npm run build 2>/dev/null || true

FROM serversideup/php:8.2-fpm-nginx
USER root
COPY --from=vendor /app/vendor /var/www/html/vendor
COPY --from=build /app/public/build /var/www/html/public/build
COPY . /var/www/html
RUN chown -R webuser:webgroup /var/www/html/storage /var/www/html/bootstrap/cache && \
    chmod -R 775 /var/www/html/storage /var/www/html/bootstrap/cache
USER webuser
